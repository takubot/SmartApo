{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=based-template-app",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "serve:html": "python -m http.server 5000",
    "serve:html:auth": "python -c \"import http.server,socketserver;H=type('H',(http.server.SimpleHTTPRequestHandler,),{'do_GET':lambda self:((setattr(self,'path','/index_auth.html') if self.path in ('/','') else None),http.server.SimpleHTTPRequestHandler.do_GET(self))[1]});socketserver.TCPServer(('',5050),H).serve_forever()\"",
    "dev:filter": "cross-env-shell npx turbo run dev --filter=$npm_config_filter",
    "build:filter": "cross-env-shell npx turbo run build --filter=$npm_config_filter",
    "start:filter": "cross-env-shell npx turbo run start --filter=$npm_config_filter",
    "lint:filter": "cross-env-shell npx turbo run lint --filter=$npm_config_filter",
    "check-types:filter": "cross-env-shell npx turbo run check-types --filter=$npm_config_filter",
    "uv:dev": "uv --project python/domain/based-template-svc run -m python.domain.based-template-svc.src.main",
    "uv:dev:filter": "cross-env-shell uv --project python/domain/$npm_config_uvdev run -m python.domain.$npm_config_uvdev.src.main",
    "uv:dev:file": "uv --project python/core/c_file_cloudrun_job run -m python.core.c_file_cloudrun_job.src.main",
    "uv:lint:filter": "cross-env-shell uv --project python run ruff check python/domain/$npm_config_uvdev/src",
    "uv:format": "uv --project python run ruff format",
    "uv:lint:fix": "uv --project python run ruff check . --fix",
    "uv:format:filter": "cross-env-shell uv --project python run ruff format python/domain/$npm_config_uvdev/src",
    "uv:package-install": "cd python && uv sync --all-packages",
    "gen:openapi:yaml": "uv --project python run scripts/gen_openapi.py --fmt yaml",
    "check:openapi:yaml": "uv --project python run scripts/gen_openapi.py --fmt yaml --check",
    "gen:openapi:redocly": "uv --project python run scripts/gen_redocly.py",
    "gen:openapi:types": "npx openapi-typescript packages/api-contracts/src/yaml/based_template.yaml -o packages/api-contracts/src/types/based_template.d.ts",
    "gen:openapi:zschema": "npx tsx scripts/gen_zod_schema.ts",
    "gen:openapi:services": "uv --project python run scripts/gen_service_functions.py",
    "gen:openapi:exports": "uv --project python run scripts/gen_exports.py",
    "gen:openapi:all": "npm run gen:openapi:yaml && npm run gen:openapi:redocly && npm run gen:openapi:types && npm run gen:openapi:zschema && npm run gen:openapi:services && npm run gen:openapi:exports && npm run format",
    "glogin": "gcloud auth application-default login --project doppel-dev-461016",
    "uv:create:table": "uv --project python/domain/based-template-svc run python python/domain/based-template-svc/src/database_utils/db_ops.py",
    "uv:check:migration": "uv --project python/domain/based-template-svc run python python/domain/based-template-svc/src/database_utils/db_migration_check.py",
    "uv:create:mock": "cross-env-shell uv --project python/domain/based-template-svc run python python/domain/based-template-svc/src/database_utils/db_mock.py --group-id $npm_config_group_id",
    "db:diff:ddl": "uv --project python run python/domain/based-template-svc/src/database_utils/db_ops_query.py",
    "db:gen:er": "uv --project python run python/domain/based-template-svc/src/database_utils/db_ops_er.py",
    "alembic:revision": "cross-env-shell \"cd python/domain/based-template-svc && uv run alembic revision --autogenerate -m \\\"$npm_config_message\\\"\"",
    "job:dev": "powershell -Command \"cd python/job/workflows; python local_dev_runner.py $env:npm_config_filter\"",
    "job:test:chunk_audio": "uv --project python/job/chunk_audio run python -m src.test.main",
    "ngrok": "powershell -Command \"Start-Process powershell -ArgumentList '-NoExit', '-Command', 'Write-Host \\\"Frontend ngrok (port 3100)\\\" -ForegroundColor Cyan; npx ngrok http 3100'; Start-Sleep -Seconds 1; Start-Process powershell -ArgumentList '-NoExit', '-Command', 'Write-Host \\\"Backend ngrok (port 8080)\\\" -ForegroundColor Magenta; npx ngrok http 8080'; Start-Sleep -Seconds 1; Start-Process powershell -ArgumentList '-NoExit', '-Command', 'Write-Host \\\"Port 5000 ngrok\\\" -ForegroundColor Green; npx ngrok http 5000'\"",
    "cors:get": "cross-env-shell gsutil cors get gs://$npm_config_bucket",
    "cors:set": "cross-env-shell gsutil cors set cors-config.json gs://$npm_config_bucket"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "openapi-zod-client": "^1.18.3",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.5",
    "yaml": "^2.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@heroui/theme": "2.4.21",
    "@line/liff": "^2.27.3",
    "lodash-es": "^4.17.21",
    "openapi-fetch": "^0.14.0"
  }
}
