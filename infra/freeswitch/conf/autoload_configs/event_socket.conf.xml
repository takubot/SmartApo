<!--
  FreeSWITCH Event Socket 設定
  FastAPI バックエンドからの Inbound ESL 接続を許可する。

  セキュリティ注意:
    - password は本番環境では必ず変更すること
    - listen-ip は FastAPI サーバーからのみアクセス可能なIPに制限推奨
    - ファイアウォールで 8021 ポートを外部から遮断すること
-->
<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <!-- ESL リスンアドレス
         0.0.0.0 = 全インターフェース (Docker/K8s環境向け)
         本番では FastAPI サーバーのIPに制限推奨 -->
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>

    <!-- ESL 認証パスワード (env: FREESWITCH_ESL_PASSWORD と一致させる) -->
    <param name="password" value="ClueCon"/>

    <!-- ACL (アクセス制御リスト) -->
    <!-- <param name="apply-inbound-acl" value="loopback.auto"/> -->
  </settings>
</configuration>
