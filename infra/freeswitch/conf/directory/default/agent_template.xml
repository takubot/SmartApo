      <variable name="rtp_secure_media" value="true"/>
      <variable name="rtp_secure_media_inbound" value="true"/>
      <variable name="rtp_secure_media_outbound" value="true"/>
      <variable name="bypass_media" value="false"/>
    </variables>
  </user>

</include>
