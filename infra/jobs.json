{
  "app_name": "doppel",

  "region": "asia-northeast1",
  "project_cd": "mitra-shared-cicd",
  "repo_name": "doppel",

  "runtime_project": {
    "dev": "doppel-dev-461016",
    "stg": "doppel-stg",
    "prod": "doppel-prod"
  },

  "service_account": {
    "dev": "cd-exec@doppel-dev-461016.iam.gserviceaccount.com",
    "stg": "cd-exec@doppel-stg.iam.gserviceaccount.com",
    "prod": "cd-exec@doppel-prod.iam.gserviceaccount.com"
  },
  "vpc_connector": {
    "dev": "",
    "stg": "",
    "prod": ""
  },

  "env_vars": {
    "dev": {
      "ENV": "dev",
      "LOG_LEVEL": "INFO"
    },
    "stg": {
      "ENV": "stg",
      "LOG_LEVEL": "INFO"
    },
    "prod": {
      "ENV": "prod",
      "LOG_LEVEL": "INFO"
    }
  },

  "defaults": {
    "retries": 3,
    "timeout_seconds": 900,
    "task_count": 1,
    "parallelism": 1,
    "cpu": "1",
    "memory": "1Gi",
    "cb_timeout": "600s",
    "image_tag": "latest",
    "short_sha": "$SHORT_SHA"
  },

  "jobs": [
    {
      "job_name": "chunk-audio",
      "job_dir": "chunk-audio-job",
      "image_name": "chunk-audio-job",
      "dockerfile_path": "python/job/chunk_audio/dockerfile",
      "build_context": ".",
      "command": ["python"],
      "args": ["-m", "src.main"],
      "timeout_seconds": 10800,
      "cpu": "2",
      "memory": "8Gi"
    },
    {
      "job_name": "chunk-document",
      "job_dir": "chunk-document-job",
      "image_name": "chunk-document-job",
      "dockerfile_path": "python/job/chunk_document/dockerfile",
